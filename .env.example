# Copy this file to ".env" in this same folder (the repo's top folder), then
# replace the placeholder below with your real OpenRouter key and save.
#
#   macOS / Linux:  cp .env.example .env
#   Windows:        copy .env.example .env
#
# The .env file is git-ignored, so your key never enters the repo. Every pattern
# under this repo reads this one file, so you only set your key once. Edit the
# copy by hand in your editor. Do not paste your key into a chat or a command.
OPENROUTER_API_KEY=sk-or-v1-REPLACE-WITH-YOUR-KEY
